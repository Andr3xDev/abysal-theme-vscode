    {
      "scope": [
        "entity.other.attribute-name.html.vue"
      ],
      "settings": {
        "foreground": "#2c9279"
      }
    },
    {
      "scope": [
        "invalid.illegal.unrecognized-tag.html"
      ],
      "settings": {
        "fontStyle": "normal"
      }
