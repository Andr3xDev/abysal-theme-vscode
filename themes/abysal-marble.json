  "rules": [
    {
      "token": "comment",
      "foreground": "666666"
    },
    {
      "token": "punctuation.definition.comment",
      "foreground": "666666"
    },
    {
      "token": "string.comment",
      "foreground": "666666"
    },
    {
      "token": "delimiter.bracket",
      "foreground": "555555"
    },
    {
      "token": "delimiter",
      "foreground": "555555"
    },
    {
      "token": "invalid.illegal.character-not-allowed-here.html",
      "foreground": "555555"
    },
    {
      "token": "keyword.operator.rest",
      "foreground": "555555"
    },
    {
      "token": "keyword.operator.spread",
      "foreground": "555555"
    },
    {
      "token": "keyword.operator.type.annotation",
      "foreground": "555555"
    },
    {
      "token": "keyword.operator.relational",
      "foreground": "555555"
    },
    {
      "token": "keyword.operator.assignment",
      "foreground": "555555"
    },
    {
      "token": "keyword.operator.type",
      "foreground": "555555"
    },
    {
      "token": "meta.brace",
      "foreground": "555555"
    },
    {
      "token": "meta.tag.block.any.html",
      "foreground": "555555"
    },
    {
      "token": "meta.tag.inline.any.html",
      "foreground": "555555"
    },
    {
      "token": "meta.tag.structure.input.void.html",
      "foreground": "555555"
    },
    {
      "token": "meta.type.annotation",
      "foreground": "555555"
    },
    {
      "token": "meta.embedded.block.github-actions-expression",
      "foreground": "555555"
    },
    {
      "token": "storage.type.function.arrow",
      "foreground": "555555"
    },
    {
      "token": "meta.objectliteral.ts",
      "foreground": "555555"
    },
    {
      "token": "punctuation",
      "foreground": "555555"
    },
    {
      "token": "punctuation.definition.string.begin.html.vue",
      "foreground": "555555"
    },
    {
      "token": "punctuation.definition.string.end.html.vue",
      "foreground": "555555"
    },
    {
      "token": "constant",
      "foreground": "b55b25"
    },
    {
      "token": "entity.name.constant",
      "foreground": "b55b25"
    },
    {
      "token": "variable.language",
      "foreground": "b55b25"
    },
    {
      "token": "meta.definition.variable",
      "foreground": "b55b25"
    },
    {
      "token": "entity",
      "foreground": "2c9279"
    },
    {
      "token": "entity.name",
      "foreground": "2c9279"
    },
    {
      "token": "variable.parameter.function",
      "foreground": "2f2f2f"
    },
    {
      "token": "entity.name.tag",
      "foreground": "2c9279"
    },
    {
      "token": "tag.html",
      "foreground": "2c9279"
    },
    {
      "token": "entity.name.function",
      "foreground": "2c9279"
    },
    {
      "token": "keyword",
      "foreground": "2c9279"
