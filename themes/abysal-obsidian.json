      "settings": {
        "foreground": "#6b92e3"
      }
    },
    {
      "scope": "namespace",
      "settings": {
        "foreground": "#b87bce"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment.compound",
        "meta.var.expr.ts"
      ],
      "settings": {
        "foreground": "#d47779"
      }
    },
    {
      "scope": "invalid.broken",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "invalid.illegal",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "invalid.unimplemented",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "carriage-return",
      "settings": {
        "fontStyle": "italic underline",
        "background": "#f97583",
        "foreground": "#24292e",
        "content": "^M"
      }
    },
    {
      "scope": "message.error",
      "settings": {
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "string variable",
      "settings": {
        "foreground": "#e28e5a"
      }
    },
    {
      "scope": [
        "source.regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#e28e5a"
      }
    },
    {
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": {
        "foreground": "#e28e5a"
      }
    },
    {
      "scope": "string.regexp constant.character.escape",
      "settings": {
        "foreground": "#d1b171"
      }
    },
    {
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#e28e5a"
      }
    },
    {
      "scope": [
        "keyword.operator.quantifier.regexp",
        "constant.numeric",
        "number"
      ],
      "settings": {
        "foreground": "#6b92e3"
      }
    },
    {
      "scope": [
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#d47779"
      }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language"
      ],
      "settings": {
        "foreground": "#52c9b0"
      }
    },
    {
      "scope": "meta.module-reference",
      "settings": {
        "foreground": "#52c9b0"
      }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#e28e5a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#52c9b0"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#6b92e3"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d4d4d4"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#d4d4d4"
      }
    },
    {
      "scope": "markup.raw",
      "settings": {
        "foreground": "#52c9b0"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "background": "#86181d",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "background": "#144620",
        "foreground": "#85e89d"
      }
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "background": "#c24e00",
        "foreground": "#ffab70"
      }
    },
    {
      "scope": [
        "markup.ignored",
        "markup.untracked"
      ],
      "settings": {
        "foreground": "#2f363d",
        "background": "#79b8ff"
      }
    },
    {
      "scope": "meta.diff.range",
      "settings": {
        "foreground": "#b392f0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#79b8ff"
      }
    },
    {
      "scope": "meta.separator",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#79b8ff"
      }
    },
    {
      "scope": "meta.output",
      "settings": {
        "foreground": "#79b8ff"
      }
    },
    {
      "scope": [
        "brackethighlighter.tag",
        "brackethighlighter.curly",
        "brackethighlighter.round",
        "brackethighlighter.square",
        "brackethighlighter.angle",
        "brackethighlighter.quote"
      ],
      "settings": {
        "foreground": "#d1d5da"
      }
    },
    {
      "scope": "brackethighlighter.unmatched",
      "settings": {
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": [
        "constant.other.reference.link",
        "string.other.link",
        "punctuation.definition.string.begin.markdown",
        "punctuation.definition.string.end.markdown"
      ],
      "settings": {
        "foreground": "#e28e5a"
      }
    },
    {
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown"
      ],
      "settings": {
        "foreground": "#8c8c8c88",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "type.identifier",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#6b92e3"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.html.vue"
      ],
      "settings": {
        "foreground": "#52c9b0"
      }
    },
    {
      "scope": [
        "invalid.illegal.unrecognized-tag.html"
      ],
      "settings": {
        "fontStyle": "normal"
      }
    }
  ],
  "rules": [
    {
      "token": "comment",
      "foreground": "737373"
    },
    {
      "token": "punctuation.definition.comment",
      "foreground": "737373"
    },
    {
      "token": "string.comment",
      "foreground": "737373"
    },
    {
      "token": "delimiter.bracket",
      "foreground": "8c8c8c"
    },
    {
      "token": "delimiter",
      "foreground": "8c8c8c"
    },
    {
      "token": "invalid.illegal.character-not-allowed-here.html",
      "foreground": "8c8c8c"
    },
    {
      "token": "keyword.operator.rest",
      "foreground": "8c8c8c"
    },
    {
      "token": "keyword.operator.spread",
      "foreground": "8c8c8c"
    },
    {
      "token": "keyword.operator.type.annotation",
      "foreground": "8c8c8c"
    },
    {
      "token": "keyword.operator.relational",
      "foreground": "8c8c8c"
    },
    {
      "token": "keyword.operator.assignment",
      "foreground": "8c8c8c"
    },
    {
      "token": "keyword.operator.type",
      "foreground": "8c8c8c"
    },
    {
      "token": "meta.brace",
      "foreground": "8c8c8c"
    },
    {
      "token": "meta.tag.block.any.html",
      "foreground": "8c8c8c"
    },
    {
      "token": "meta.tag.inline.any.html",
      "foreground": "8c8c8c"
    },
    {
      "token": "meta.tag.structure.input.void.html",
      "foreground": "8c8c8c"
    },
    {
      "token": "meta.type.annotation",
      "foreground": "8c8c8c"
    },
    {
      "token": "meta.embedded.block.github-actions-expression",
      "foreground": "8c8c8c"
    },
    {
      "token": "storage.type.function.arrow",
      "foreground": "8c8c8c"
    },
    {
      "token": "meta.objectliteral.ts",
      "foreground": "8c8c8c"
    },
    {
      "token": "punctuation",
      "foreground": "8c8c8c"
    },
    {
      "token": "punctuation.definition.string.begin.html.vue",
      "foreground": "8c8c8c"
    },
    {
      "token": "punctuation.definition.string.end.html.vue",
      "foreground": "8c8c8c"
    },
    {
      "token": "constant",
      "foreground": "e28e5a"
    },
    {
      "token": "entity.name.constant",
      "foreground": "e28e5a"
